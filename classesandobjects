//types of constructor
 //implementation of non parametrised constructor
#include<bits/stdc++.h>
using namespace std;
class Person{
    private: 
    string name;
    int age;
    float height;
    //initilizing values to member variables using non parametrized constructor
    //constructor has same name as the class
   public:
    Person(){
        name="of";
        age=0;
        height=0.0f;
    }
    int getData(){
        cout<<name<<endl;
        cout<<age<<endl;
        cout<<height<<endl;
    }
};
int main(){
    Person obj;
    obj.getData();
    return 0;
}





////////permetrised constructors

#include<bits/stdc++.h>
using namespace std;
class Person{
    private: 
    string name;
    int age;
    float height;
    //initilizing values to member variables using parametrized constructor
    //constructor has same name as the class
   public:
    Person(string name_a,int age_a,float height_a){
        name=name_a;
        age=age_a;
        height=height_a;
    }
    int getData(){
        cout<<name<<endl;
        cout<<age<<endl;
        cout<<height<<endl;
    }
};
int main(){
    Person obj("rishabh",24,5.10);
    obj.getData();
    return 0;
}





/////////COPY CONSTRUCTOR

#include<bits/stdc++.h>
using namespace std;
class Person{
    private:
    int age;
    string name;
    float height;
    public:
    Person(string a_name,int a_age,float a_height){
        name=a_name;
        height=a_height;
        age = a_age;
        
    }
    void getData(){
        cout<<name<<endl;
        cout<<age<<endl;
        cout<<height<<endl;
    }
    
};
int main(){
    Person obj1("rishabh", 24,5.10);
.//////this is the point of differcene
    Person obj2(obj1);
    obj2.getData();
}
