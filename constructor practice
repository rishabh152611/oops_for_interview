#include<bits/stdc++.h>
using namespace std;
class PhoneDetails{
    private:
    string name;
    int ram;
    string processor;
    float battery;
    public:
    PhoneDetails(string name_a,int ram_a,string processor_a,float batter_a){
        name = name_a;
        ram= ram_a;
        processor=processor_a;
        battery=batter_a;
    }
    PhoneDetails(PhoneDetails&customer1){
        name = customer1.name;
        ram = customer1.ram;
        processor=customer1.processor;
        battery=customer1.battery;
    }
    void getData(){
        cout<<name<<endl;
        cout<<ram<<endl;
        cout<<processor<<endl;
        cout<<battery<<endl;
        
        
    }
    
};
int main(){
    PhoneDetails customer1("anshika",8,"snapdragon",81.3);
    PhoneDetails customer2(customer1);
   customer2.getData();
}
