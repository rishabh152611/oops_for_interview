Static functions
#include <bits/stdc++.h>
using namespace std;

class Alpha {
public:
    int a;
    int b;

    Alpha() {
        a = 5;
        b = 5;
        stat++;
    }

    static int stat;

    static int print() {
        stat++;
        return stat;
    }
};

int Alpha::stat = 0;

int main() {
    Alpha a1;
    Alpha a2;

    cout << Alpha::stat << endl;   // 2
    cout << Alpha::print() << endl; // 3
}
